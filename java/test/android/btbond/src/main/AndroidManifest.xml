<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLUETOOTH and BLUETOOTH_ADMIN are deliberately absent: both carry maxSdkVersion="30" in the
         platform manifest and this app's minSdk is 34, so they could never be granted. The app does
         not scan (the peer address comes from the harness), so BLUETOOTH_SCAN is not needed either. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Granted only because the app is installed as a privileged system app with a matching
         privapp-permissions allowlist; lets it auto-confirm pairing (setPairingConfirmation). -->
    <uses-permission android:name="android.permission.BLUETOOTH_PRIVILEGED" />

    <application android:label="btbond">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
