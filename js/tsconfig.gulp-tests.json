{
    "compilerOptions": {
        "lib": ["dom", "es2020"],
        "target": "es2020",
        "module": "es2020",
        "moduleResolution": "bundler",
        "strict": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noEmitOnError": true
    }
}
