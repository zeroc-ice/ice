{
    "name": "ice-js",
    "private": true,
    "engines": {
        "node": ">=22.16.0"
    },
    "workspaces": [
        "packages/*"
    ],
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-strip": "^3.0.4",
        "@rollup/plugin-typescript": "^12.1.0",
        "@types/node": "^26.0.0",
        "c8": "^11.0.0",
        "del": "^8.0.0",
        "esbuild": "^0.28.1",
        "eslint": "^10.5.0",
        "globals": "^17.7.0",
        "gulp": "^5.0.1",
        "http-server": "^14.1.1",
        "prettier": "^3.8.4",
        "rollup": "^4.62.2",
        "test_nested_modules": "file:packages/test/Ice/moduleAggregation/module",
        "ts-loader": "^9.6.2",
        "tslib": "^2.8.1",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0",
        "webpack": "^5.106.2"
    },
    "scripts": {
        "build": "gulp",
        "build-doc": "node dts-bundle.js && npx typedoc --tsconfig tsconfig.typedoc.json --name '@zeroc/ice' --router structure dist/bundle.d.ts --disableGit --disableSources --customFooterHtml '© ZeroC' --favicon ../assets/favicon-96x96.png --hostedBaseUrl https://code.zeroc.com/ice/main/api/javascript/ --hideGenerator",
        "dist": "gulp dist",
        "clean": "gulp clean",
        "test:unplugin": "node --test packages/test/Slice/unplugin/*/*.test.ts"
    }
}
