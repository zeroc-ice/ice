{
    "compilerOptions": {
        "lib": ["dom", "es2020", "esnext.disposable"],
        "target": "es2020",
        "module": "es2020",
        "moduleResolution": "bundler",
        "types": ["node"],
        "strict": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noEmitOnError": true
    },
    "files": ["./dist/bundle.d.ts"]
}
